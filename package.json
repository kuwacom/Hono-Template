{
  "name": "hono-restful-template",
  "description": "Honoを使ったNode.js / Cloudflare Workers両対応のREST APIテンプレート",
  "version": "1.0.0",
  "author": "kuwa",
  "keywords": [
    "typescript",
    "hono",
    "template",
    "cloudflare-workers",
    "nodejs"
  ],
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/node.ts",
    "dev:worker": "wrangler dev",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\" --no-error-on-unmatched-pattern",
    "lint:fix": "npm run lint -- --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "build": "npm run typecheck && npm run build:node",
    "build:node": "tsup src/node.ts --format esm --target node20 --out-dir dist --clean",
    "check:worker": "wrangler deploy --dry-run",
    "start": "node dist/node.js",
    "deploy:worker": "wrangler deploy"
  },
  "license": "MIT",
  "dependencies": {
    "@hono/zod-validator": "^0.7.5",
    "@hono/node-server": "^1.13.8",
    "dotenv": "^16.6.1",
    "hono": "^4.8.5",
    "tslog": "^4.10.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.1",
    "tsup": "^8.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "wrangler": "^4.18.0"
  }
}
